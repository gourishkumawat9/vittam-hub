# ─────────────────────────────────────────────────────────────
# VittamHub — Environment Variables (example)
# Copy to .env and fill in. Never commit the real .env file.
# ─────────────────────────────────────────────────────────────

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
APP_NAME=VittamHub

# --- Frontend (exposed to the browser — no secrets here) ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Database (Postgres — Neon/Supabase in prod) ---
DATABASE_URL=postgresql://user:password@localhost:5432/vittamhub
DATABASE_URL_POOLED=postgresql://user:password@localhost:5432/vittamhub?pgbouncer=true
SHADOW_DATABASE_URL=postgresql://user:password@localhost:5432/vittamhub_shadow

# --- Cache / Queues (Upstash Redis) ---
REDIS_URL=rediss://default:password@host:6379

# --- Auth ---
JWT_ACCESS_SECRET=replace-with-32-byte-random-secret
JWT_REFRESH_SECRET=replace-with-different-32-byte-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
SESSION_COOKIE_NAME=vh_session

# --- OAuth Providers ---
# Apple Sign-In, Microsoft, and SAML/OIDC SSO are documented but not yet
# implemented — see docs/09-authentication-security.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- CAPTCHA (Cloudflare Turnstile) ---
# Leave blank in local dev — auth flows skip verification when unset.
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# --- Object Storage (Cloudflare R2, S3-compatible) ---
STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=vittamhub-media
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_CDN_URL=https://media.vittamhub.com

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM="VittamHub <no-reply@vittamhub.com>"

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Search / Discovery (optional: Algolia or Meilisearch) ---
SEARCH_HOST=
SEARCH_API_KEY=

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Feature Flags ---
FEATURE_INVESTOR_MATCHING=true
FEATURE_PUBLIC_STARTUP_PROFILES=true
