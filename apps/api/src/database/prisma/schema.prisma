// ─── Identity & auth ────────────────────────────────────────────────────

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  email              String              @unique
  passwordHash       String? // null for OAuth-only accounts
  fullName           String
  avatarUrl          String?
  role               UserRole
  verificationStatus VerificationStatus  @default(UNVERIFIED)
  emailVerifiedAt    DateTime?
  twoFactorEnabled   Boolean             @default(false)
  twoFactorSecret    String? // encrypted at rest by the app layer, never returned by any endpoint
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime? // soft delete — preserves FK history for audit logs

  profile             UserProfile?
  startup             Startup?
  investorProfile     Investor?
  mentorProfile       MentorProfile?
  incubatorProfile    IncubatorProfile?
  universityProfile   UniversityProfile?
  serviceProviderProfile ServiceProviderProfile?
  jobSeekerProfile    JobSeekerProfile?
  oauthAccounts       OAuthAccount[]
  refreshTokens       RefreshToken[]
  otpCodes            OtpCode[]
  passwordResetTokens PasswordResetToken[]
  mfaRecoveryCodes    MfaRecoveryCode[]
  documents           Document[]
  notifications       Notification[]
  sentConnections     Connection[]        @relation("ConnectionRequester")
  receivedConnections Connection[]        @relation("ConnectionRecipient")
  sentMessages        Message[]           @relation("MessageSender")
  subscription        Subscription?
  auditLogs           AuditLog[]
  startupFollows      StartupFollow[]
  startupProfileViews StartupProfileView[]
  pipelineEntries     PipelineEntry[]
  investments         Investment[]
  sentMentorBookings     MentorBookingRequest[] @relation("MentorBookingFounder")
  receivedMentorBookings MentorBookingRequest[] @relation("MentorBookingMentor")
  jobApplications        JobApplication[]
  posts                  Post[]
  comments               Comment[]
  likes                  Like[]
  pollVotes              PollVote[]
  eventRsvps             EventRsvp[]
  postBookmarks          PostBookmark[]
  sentFollows            Follow[] @relation("Follower")
  receivedFollows        Follow[] @relation("Following")
  founderReviewsGiven    FounderReview[] @relation("FounderReviewMentor")
  founderReviewsReceived FounderReview[] @relation("FounderReviewFounder")

  @@index([role])
  @@map("users")
}

// Shared "personal details" extension — every role's onboarding starts with
// this same form (Step 1 in the founder wizard, "Personal Details" in every
// other role's flow) before branching into role-specific fields, so these
// columns live once instead of being duplicated across seven profile tables.
model UserProfile {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @unique @db.Uuid
  mobileNumber   String?
  dateOfBirth    DateTime?
  gender         Gender?
  nationality    String?
  linkedinUrl    String?
  githubUrl      String?
  portfolioUrl   String?
  city           String?
  state          String?
  country        String?
  bio            String?
  yearsOfExperience Int? // backs the "founder experience" discovery filter — see StartupsService.search

  // Onboarding wizard state — see docs/11-onboarding-architecture.md.
  // `onboardingDraft` accumulates every step's answers as JSON so autosave
  // never has to satisfy full relational constraints on a half-finished
  // wizard; `publish()` validates the complete draft and commits it into
  // the normalized tables below in one transaction.
  onboardingStatus OnboardingStatus @default(NOT_STARTED)
  onboardingStep   Int              @default(0)
  onboardingDraft  Json?
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model OAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  provider          String // "google" | "linkedin" | "github" | "apple" | "microsoft"
  providerAccountId String
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

// Doubles as the "session" record for the Session Management / Device List
// UI — one row per active refresh token, one refresh token per device/browser.
model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique // never store the raw token — see docs/09-authentication-security.md
  deviceLabel String? // parsed from User-Agent at issuance, e.g. "Chrome on macOS"
  userAgent   String?
  ipAddress   String?
  rememberMe  Boolean   @default(false) // short session (browser-close) vs. long-lived, see auth.service.ts
  expiresAt   DateTime
  lastUsedAt  DateTime  @default(now())
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Short-lived codes for email verification and login-time MFA (email fallback).
// TOTP MFA doesn't need this — it's verified against `User.twoFactorSecret` directly.
model OtpCode {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  purpose     OtpPurpose
  codeHash    String // SHA-256 of the 6-digit code — same "never store raw secrets" rule as refresh tokens
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int        @default(0) // capped in service logic to blunt brute-force guessing
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("otp_codes")
}

// Link-based reset (emailed URL), deliberately separate from OtpCode — see docs/09-authentication-security.md.
model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// One-time-use backup codes issued at MFA enrollment for account recovery if the authenticator device is lost.
model MfaRecoveryCode {
  id       String    @id @default(uuid()) @db.Uuid
  userId   String    @db.Uuid
  codeHash String
  usedAt   DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_recovery_codes")
}

// Generic verification document, keyed to the uploading user rather than a
// specific profile table — every role's "Verification Documents" step
// (Startup Step 8, Investor, Mentor, ...) writes here uniformly.
model Document {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  type           DocumentType
  fileUrl        String
  fileName       String
  uploadedAt     DateTime     @default(now())
  verifiedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("documents")
}

// ─── Startup domain ─────────────────────────────────────────────────────

model Startup {
  id                    String              @id @default(uuid()) @db.Uuid
  ownerId               String              @unique @db.Uuid
  name                  String
  slug                  String              @unique
  tagline               String
  description           String
  logoUrl               String?
  website               String?
  industry              String
  subIndustry           String?
  stage                 StartupStage        @default(IDEA)
  foundedYear            Int
  registrationStatus    RegistrationStatus  @default(NOT_REGISTERED)
  companyType           CompanyType?
  headquarters          String? // city/country the company is legally headquartered in
  businessModelSummary  String? // free-text model description (e.g. "subscription", "marketplace take-rate")
  mission               String?
  vision                String?
  problemStatement      String?
  solution              String?
  uniqueValueProposition String?
  teamSize              Int                 @default(1)
  hiringStatus          HiringStatus        @default(NOT_HIRING)
  openRoles             String[]
  location              String
  fundingRaisedUsd      Decimal             @default(0) @db.Decimal(14, 2)
  isFundraising         Boolean             @default(false)
  verificationStatus    VerificationStatus  @default(UNVERIFIED)
  verifiedAt            DateTime? // set by VerificationEngineService when verificationStatus automatically reaches VERIFIED — see modules/verification
  isPublic              Boolean             @default(true)
  termsAcceptedAt       DateTime? // Step 10 "Accept Terms" — e-signature is the typed founder name + this timestamp
  publishedAt           DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt              DateTime?

  owner       User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamMembers StartupTeamMember[]
  product     StartupProduct?
  market      StartupMarket?
  traction    StartupTraction?
  funding     StartupFunding?
  preference  StartupPreference?
  connections Connection[]
  milestones  StartupMilestone[]
  followedBy  StartupFollow[]
  profileViews StartupProfileView[]
  pipelineEntries PipelineEntry[]
  investments Investment[]
  mentorBookingRequests MentorBookingRequest[]
  jobs        Job[]
  posts       Post[]

  @@index([industry])
  @@index([stage])
  @@index([isFundraising])
  @@index([isPublic, verificationStatus]) // backs the public discovery feed's primary filter
  @@map("startups")
}

// Founder-curated milestones ("Idea Created" -> "Product Launch") shown on the
// public profile in chronological order and counted as one TrustScore factor.
model StartupMilestone {
  id           String        @id @default(uuid()) @db.Uuid
  startupId    String        @db.Uuid
  type         MilestoneType
  title        String
  description  String?
  achievedAt   DateTime
  evidenceUrls String[]      @default([]) // optional photos/links/documents — type is a rendering concern (sniff by extension), not storage, mirrors Post.mediaUrls
  createdAt    DateTime      @default(now())

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId, achievedAt])
  @@map("startup_milestones")
}

model StartupTeamMember {
  id          String              @id @default(uuid()) @db.Uuid
  startupId   String              @db.Uuid
  category    TeamMemberCategory  @default(EMPLOYEE)
  fullName    String
  role        String // job title, free text
  linkedinUrl String?
  photoUrl    String?
  createdAt   DateTime            @default(now())

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
  @@map("startup_team_members")
}

// Step 3 — Product Details. 1:1 with Startup; split out because it's a distinct, optional-until-MVP concern.
model StartupProduct {
  id                String   @id @default(uuid()) @db.Uuid
  startupId         String   @unique @db.Uuid
  productName       String?
  description       String?
  currentVersion    String?
  website           String?
  appStoreUrl       String?
  playStoreUrl      String?
  demoVideoUrl      String?
  pitchVideoUrl     String?
  screenshots       String[]
  technologyStack   String[]
  hasApi            Boolean  @default(false)
  updatedAt         DateTime @updatedAt

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("startup_products")
}

// Step 4 — Market Details. Personas/competitors are semi-structured lists — JSON keeps the schema stable as their shape evolves.
model StartupMarket {
  id                    String          @id @default(uuid()) @db.Uuid
  startupId             String          @unique @db.Uuid
  targetAudience        String?
  targetGeography       String[]
  primaryCustomer       String?
  customerModel         CustomerModel[]
  tamUsd                Decimal?        @db.Decimal(16, 2)
  samUsd                Decimal?        @db.Decimal(16, 2)
  somUsd                Decimal?        @db.Decimal(16, 2)
  customerPersonas      Json?
  competitors           Json?
  competitiveAdvantage  String?
  goToMarketStrategy    String?
  updatedAt             DateTime        @updatedAt

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("startup_markets")
}

// Step 6 — Traction.
model StartupTraction {
  id                    String   @id @default(uuid()) @db.Uuid
  startupId             String   @unique @db.Uuid
  monthlyRevenueUsd     Decimal? @db.Decimal(14, 2)
  arrUsd                Decimal? @db.Decimal(14, 2)
  mrrUsd                Decimal? @db.Decimal(14, 2)
  totalUsers            Int?
  totalCustomers        Int?
  downloads             Int?
  retentionRatePercent  Decimal? @db.Decimal(5, 2)
  growthRatePercent     Decimal? @db.Decimal(6, 2)
  partnerships          String[]
  awards                String[]
  patents               String[]
  mediaMentions         String[]
  updatedAt             DateTime @updatedAt

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("startup_tractions")
}

// Step 7 — Funding.
model StartupFunding {
  id                  String        @id @default(uuid()) @db.Uuid
  startupId           String        @unique @db.Uuid
  fundingTypes        FundingType[]
  currentRaiseUsd     Decimal?      @db.Decimal(14, 2)
  fundingGoalUsd      Decimal?      @db.Decimal(14, 2)
  valuationUsd        Decimal?      @db.Decimal(16, 2)
  previousInvestors   String[]
  useOfFunds          String?
  runwayMonths        Int?
  monthlyBurnRateUsd  Decimal?      @db.Decimal(14, 2)
  updatedAt           DateTime      @updatedAt

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("startup_fundings")
}

// Step 9 — Preferences ("Looking For").
model StartupPreference {
  id         String           @id @default(uuid()) @db.Uuid
  startupId  String           @unique @db.Uuid
  lookingFor LookingForType[]
  updatedAt  DateTime         @updatedAt

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("startup_preferences")
}

// A startup's own job postings — separate from the `jobs` BullMQ email
// queue module of the same informal name; this is the hiring-portal domain.
model Job {
  id             String         @id @default(uuid()) @db.Uuid
  startupId      String         @db.Uuid
  title          String
  description    String
  employmentType EmploymentType
  location       String
  isRemote       Boolean        @default(false)
  skills         String[]
  minSalaryUsd   Decimal?       @db.Decimal(12, 2)
  maxSalaryUsd   Decimal?       @db.Decimal(12, 2)
  status         JobStatus      @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  startup      Startup         @relation(fields: [startupId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([startupId])
  @@index([status])
  @@map("jobs_board_postings")
}

// `resumeUrl`/`coverLetter` are captured on the row at apply-time rather than
// joined from JobSeekerProfile — mirrors Connection.pitchDeckUrl's precedent,
// so applying never requires completed JOB_SEEKER onboarding.
model JobApplication {
  id           String            @id @default(uuid()) @db.Uuid
  jobId        String            @db.Uuid
  applicantId  String            @db.Uuid
  resumeUrl    String
  coverLetter  String?
  status       ApplicationStatus @default(SUBMITTED)
  createdAt    DateTime          @default(now())

  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant User @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@map("job_applications")
}

// ─── Other role profiles ────────────────────────────────────────────────

model Investor {
  id                  String         @id @default(uuid()) @db.Uuid
  ownerId             String         @unique @db.Uuid
  firmName            String?
  designation         String?
  investorType        InvestorType
  bio                 String
  logoUrl             String?
  website             String?
  checkSizeMinUsd     Decimal        @default(0) @db.Decimal(14, 2)
  checkSizeMaxUsd     Decimal        @default(0) @db.Decimal(14, 2)
  preferredStages     StartupStage[]
  preferredIndustries String[]
  preferredGeography  String[]
  portfolioCompanies  String[]
  investmentThesis    String?
  openForPitches      Boolean        @default(true)
  location            String
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  verifiedAt          DateTime? // set by VerificationEngineService — see modules/verification
  isPublic            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([investorType])
  @@index([isPublic, verificationStatus])
  @@map("investors")
}

model MentorProfile {
  id                 String        @id @default(uuid()) @db.Uuid
  ownerId            String        @unique @db.Uuid
  headline           String?
  expertise          String[]
  industries         String[]
  yearsExperience    Int?
  availability       String?
  sessionTypes       SessionType[]
  pricingModel       String? // e.g. "Free", "$150/hr", "Equity-based"
  languages          String[]
  pastStartups       String[] // free-text company names — often off-platform, so not an FK relation
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime? // set by VerificationEngineService — see modules/verification
  isPublic           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([isPublic, verificationStatus])
  @@map("mentor_profiles")
}

model IncubatorProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  ownerId               String   @unique @db.Uuid
  organizationName      String
  description           String?
  website               String?
  logoUrl               String?
  industries            String[]
  portfolioCompanies    String[]
  affiliatedMentorCount Int?
  kind                  IncubatorKind @default(INCUBATOR) // lets Accelerators surface as a filter on this same directory, no separate entity
  verificationStatus    VerificationStatus @default(UNVERIFIED)
  verifiedAt            DateTime? // set by VerificationEngineService — see modules/verification
  isPublic              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  owner    User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  programs IncubatorProgram[]

  @@index([isPublic, verificationStatus])
  @@map("incubator_profiles")
}

model IncubatorProgram {
  id                    String    @id @default(uuid()) @db.Uuid
  incubatorId           String    @db.Uuid
  name                  String
  description           String?
  durationWeeks         Int?
  applicationCycleStart DateTime?
  applicationCycleEnd   DateTime?
  applicationUrl        String? // external link founders click through to apply — no in-app application flow yet
  eligibilityCriteria   String?
  createdAt             DateTime  @default(now())

  incubator IncubatorProfile @relation(fields: [incubatorId], references: [id], onDelete: Cascade)

  @@index([incubatorId])
  @@map("incubator_programs")
}

// A founder requesting time with a mentor — deliberately not a Connection:
// no monthly quota, repeatable per pair, no messaging/meeting gate. See
// MentorBookingService.
model MentorBookingRequest {
  id             String        @id @default(uuid()) @db.Uuid
  founderId      String        @db.Uuid
  mentorId       String        @db.Uuid
  startupId      String?       @db.Uuid
  sessionType    SessionType?
  message        String
  preferredTimes String?
  status         BookingStatus @default(PENDING)
  respondedAt    DateTime?
  createdAt      DateTime      @default(now())

  founder User     @relation("MentorBookingFounder", fields: [founderId], references: [id], onDelete: Cascade)
  mentor  User     @relation("MentorBookingMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  startup Startup? @relation(fields: [startupId], references: [id], onDelete: SetNull)
  review  FounderReview?

  @@index([mentorId, status])
  @@index([founderId])
  @@map("mentor_booking_requests")
}

// A mentor's review of a founder after an accepted booking — feeds
// FounderReputationService. Gated on the booking being ACCEPTED (not a
// separate COMPLETED state — there's no real session-datetime field to gate
// true completion on yet); the unique constraint on bookingRequestId is what
// stops a mentor reviewing the same booking twice.
model FounderReview {
  id               String   @id @default(uuid()) @db.Uuid
  mentorId         String   @db.Uuid
  founderId        String   @db.Uuid
  bookingRequestId String   @unique @db.Uuid
  rating           Int
  comment          String?
  createdAt        DateTime @default(now())

  mentor         User                  @relation("FounderReviewMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  founder        User                  @relation("FounderReviewFounder", fields: [founderId], references: [id], onDelete: Cascade)
  bookingRequest MentorBookingRequest  @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)

  @@index([founderId])
  @@map("founder_reviews")
}

model UniversityProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  ownerId             String   @unique @db.Uuid
  institutionName     String
  affiliationType     String? // "Public" | "Private" | free text
  website             String?
  logoUrl             String?
  incubationCellName  String?
  departments         String[]
  programsOffered     String[]
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  isPublic            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([isPublic, verificationStatus])
  @@map("university_profiles")
}

model ServiceProviderProfile {
  id                 String            @id @default(uuid()) @db.Uuid
  ownerId            String            @unique @db.Uuid
  companyName        String
  categories         ServiceCategory[]
  description        String?
  pricingModel       String?
  yearsExperience    Int?
  clientsServed      Int?
  website            String?
  logoUrl            String?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  isPublic           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([isPublic, verificationStatus])
  @@map("service_provider_profiles")
}

model JobSeekerProfile {
  id                    String            @id @default(uuid()) @db.Uuid
  ownerId               String            @unique @db.Uuid
  headline              String?
  resumeUrl             String?
  skills                String[]
  preferredRoles        String[]
  expectedSalaryMinUsd  Decimal?          @db.Decimal(12, 2)
  expectedSalaryMaxUsd  Decimal?          @db.Decimal(12, 2)
  availability          AvailabilityType  @default(FLEXIBLE)
  isPublic              Boolean           @default(true)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  owner      User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  experience WorkExperienceEntry[]
  education  EducationEntry[]

  @@map("job_seeker_profiles")
}

model WorkExperienceEntry {
  id           String    @id @default(uuid()) @db.Uuid
  jobSeekerId  String    @db.Uuid
  company      String
  title        String
  startDate    DateTime?
  endDate      DateTime?
  description  String?

  jobSeeker JobSeekerProfile @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  @@index([jobSeekerId])
  @@map("work_experience_entries")
}

model EducationEntry {
  id           String  @id @default(uuid()) @db.Uuid
  jobSeekerId  String  @db.Uuid
  institution  String
  degree       String?
  fieldOfStudy String?
  startYear    Int?
  endYear      Int?

  jobSeeker JobSeekerProfile @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)

  @@index([jobSeekerId])
  @@map("education_entries")
}

// ─── Platform ────────────────────────────────────────────────────────────

// The "Smart Connect Request" — a founder can never message an investor
// directly; this is the only channel, and it's rate-limited per calendar
// month by PlanLimit.monthlyConnectRequestLimit. Chat (Message, below) only
// unlocks once status flips to ACCEPTED. See docs/12-connect-requests.md.
model Connection {
  id                   String           @id @default(uuid()) @db.Uuid
  requesterId          String           @db.Uuid
  recipientId          String           @db.Uuid
  startupId            String?          @db.Uuid
  status               ConnectionStatus @default(PENDING)
  introduction         String? // short intro + startup summary, written by the requester
  fundingRequirementUsd Int?
  pitchDeckUrl         String?
  executiveSummaryUrl  String?
  demoLinkUrl          String?
  infoRequestedAt      DateTime? // investor asked for more detail before deciding — doesn't change status, just flags it on the founder's side
  createdAt            DateTime         @default(now())
  respondedAt          DateTime?

  requester User      @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User      @relation("ConnectionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  startup   Startup?  @relation(fields: [startupId], references: [id], onDelete: SetNull)
  messages  Message[]
  meetings  Meeting[]

  @@unique([requesterId, recipientId, startupId]) // prevents duplicate pending requests
  @@index([recipientId, status])
  @@map("connections")
}

// A lightweight proposed meeting time attached to a connection — no calendar
// sync or video-call provider integration yet (see CLAUDE.md future-modules
// note); `videoCallUrl` is whatever link the two parties paste in themselves.
model Meeting {
  id           String    @id @default(uuid()) @db.Uuid
  connectionId String    @db.Uuid
  scheduledAt  DateTime
  notes        String?
  videoCallUrl String?
  createdAt    DateTime  @default(now())

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@map("meetings")
}

// A founder's own bookmark ("Saved") vs. an active follow that triggers
// update notifications ("Watchlist") are the same relationship with one flag
// — see WatchlistService for how milestone/product/funding events fan out
// to `notifyOnUpdate: true` followers only.
model StartupFollow {
  id             String   @id @default(uuid()) @db.Uuid
  investorId     String   @db.Uuid
  startupId      String   @db.Uuid
  notifyOnUpdate Boolean  @default(false)
  notes          String? // private investor note about this startup
  listName       String? // free-text grouping label — a lightweight "list" without a separate collections table
  createdAt      DateTime @default(now())

  investor User    @relation(fields: [investorId], references: [id], onDelete: Cascade)
  startup  Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([investorId, startupId])
  @@map("startup_follows")
}

// Generic user-to-user follow (follow a founder, an investor, a mentor…) —
// deliberately separate from StartupFollow, which is investor→startup with
// its own notifyOnUpdate/watchlist semantics. This is the plain "follow a
// person" mechanism network-effects features build on.
model Follow {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// Day-bucketed view log — `viewDate` (date-only) + the unique constraint is
// the throttle: one row per investor per startup per calendar day, repeat
// same-day views just increment `viewCount` rather than inserting, and only
// the first view of a new day emits a `startup.profile-viewed` event, so a
// founder never gets spammed by one investor refreshing the page repeatedly.
model StartupProfileView {
  id         String   @id @default(uuid()) @db.Uuid
  startupId  String   @db.Uuid
  investorId String   @db.Uuid
  viewDate   DateTime @db.Date
  viewCount  Int      @default(1)
  createdAt  DateTime @default(now())

  startup  Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
  investor User    @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([startupId, investorId, viewDate])
  @@index([startupId, viewDate])
  @@map("startup_profile_views")
}

// One row per (investor, startup) the investor is actively evaluating —
// the Kanban board is just this table grouped by `stage`. Reaching INVESTED
// auto-creates the matching Investment row (see PipelineService.moveStage).
model PipelineEntry {
  id         String        @id @default(uuid()) @db.Uuid
  investorId String        @db.Uuid
  startupId  String        @db.Uuid
  stage      PipelineStage @default(TARGET)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  investor User    @relation(fields: [investorId], references: [id], onDelete: Cascade)
  startup  Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([investorId, startupId])
  @@map("pipeline_entries")
}

// The investor's actual portfolio — created once a PipelineEntry reaches
// INVESTED; "Current Stage", "Revenue", "Team Size" for the portfolio card
// are read live off the Startup/StartupTraction rows, not duplicated here.
model Investment {
  id         String    @id @default(uuid()) @db.Uuid
  investorId String    @db.Uuid
  startupId  String    @db.Uuid
  investedAt DateTime  @default(now())
  amountUsd  Decimal?  @db.Decimal(14, 2)
  notes      String?
  createdAt  DateTime  @default(now())

  investor User    @relation(fields: [investorId], references: [id], onDelete: Cascade)
  startup  Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([investorId, startupId])
  @@map("investments")
}

// Unlocked only once its parent Connection is ACCEPTED — see
// MessagesService.assertCanMessage. Deliberately simple (no threads,
// reactions, or read receipts) since real-time chat infra isn't in scope yet.
model Message {
  id           String    @id @default(uuid()) @db.Uuid
  connectionId String    @db.Uuid
  senderId     String    @db.Uuid
  body         String
  attachmentUrl String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sender     User       @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@map("messages")
}

// Admin-configurable quota per plan (e.g. Free founders get N connect
// requests/month) — a row missing for a given plan means "not yet
// configured"; services fall back to a hardcoded default rather than
// failing, see PlanLimitsService.
model PlanLimit {
  id                         String           @id @default(uuid()) @db.Uuid
  plan                       SubscriptionPlan @unique
  monthlyConnectRequestLimit Int? // null = unlimited
  updatedAt                  DateTime         @updatedAt

  @@map("plan_limits")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  body      String
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// ─── Community ──────────────────────────────────────────────────────────

// One table + a type discriminator, not four separate models — FOUNDER_POST/
// STARTUP_UPDATE/ANNOUNCEMENT are structurally identical (author + optional
// startup context + body + media); an Event is "a Post with 3 extra optional
// fields," not a structurally different entity. Poll/Event get their own
// *child* tables (PollOption/PollVote, EventRsvp) because they have real
// structured child data the other types don't.
model Post {
  id            String   @id @default(uuid()) @db.Uuid
  authorId      String   @db.Uuid
  startupId     String?  @db.Uuid
  type          PostType
  body          String
  mediaUrls     String[]
  eventStartsAt DateTime?
  eventLocation String?
  eventUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  startup     Startup?      @relation(fields: [startupId], references: [id], onDelete: SetNull)
  comments    Comment[]
  likes       Like[]
  pollOptions PollOption[]
  rsvps       EventRsvp[]
  bookmarks   PostBookmark[]

  @@index([type, createdAt])
  @@index([authorId])
  @@map("posts")
}

// Flat, single-level — no nested replies, matches "keep it simple, no algorithmic ranking."
model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  authorId  String   @db.Uuid
  body      String
  createdAt DateTime @default(now())

  post   Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes  Like[]

  @@index([postId, createdAt])
  @@map("comments")
}

// Two nullable FKs with onDelete: Cascade — real referential integrity
// (unlike AuditLog's stringly-typed entityType/entityId, which intentionally
// avoids cascade). Service layer enforces exactly one of postId/commentId set.
model Like {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  postId    String?  @db.Uuid
  commentId String?  @db.Uuid
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@map("likes")
}

model PostBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  postId    String   @db.Uuid
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("post_bookmarks")
}

model PollOption {
  id    String @id @default(uuid()) @db.Uuid
  postId String @db.Uuid
  label String
  order Int

  post  Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([postId])
  @@map("poll_options")
}

// One-vote-per-poll-per-user is an app-level invariant (checked via a join
// through PollOption.postId before insert) — a plain unique on
// [userId, pollOptionId] alone wouldn't stop a user voting for two different
// options in the same poll.
model PollVote {
  id           String   @id @default(uuid()) @db.Uuid
  pollOptionId String   @db.Uuid
  userId       String   @db.Uuid
  createdAt    DateTime @default(now())

  pollOption PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pollOptionId])
  @@map("poll_votes")
}

model EventRsvp {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("event_rsvps")
}

// ─── Billing ────────────────────────────────────────────────────────────

model Subscription {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @unique @db.Uuid
  plan                 SubscriptionPlan @default(FREE)
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Compliance ─────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid // null for system-initiated actions
  action     String // e.g. "startup.verified", "user.role_changed", "auth.login"
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}
