// VittamHub database schema.
// See docs/08-database-planning.md for the ERD narrative and indexing rationale,
// and docs/11-onboarding-architecture.md for why onboarding uses a draft-JSON
// autosave + commit-on-publish pattern instead of normalizing every wizard
// step as it's typed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("SHADOW_DATABASE_URL")
}

// ─── Enums: identity & auth ─────────────────────────────────────────────

enum UserRole {
  FOUNDER
  INVESTOR
  MENTOR
  INCUBATOR
  UNIVERSITY
  SERVICE_PROVIDER
  JOB_SEEKER
  ADMIN
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  LOGIN_MFA
}

enum DocumentType {
  INCORPORATION_CERTIFICATE
  PAN
  GST
  DPIIT_RECOGNITION
  TRADEMARK
  PATENT
  PITCH_DECK
  FINANCIAL_STATEMENT
  GOVERNMENT_ID
  DIGITAL_SIGNATURE
  CAP_TABLE
  LEGAL_CONTRACT
  DUE_DILIGENCE_REPORT
  MEETING_NOTES
  OTHER
}

